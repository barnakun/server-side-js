<%- include('header') %>

<div class="container" style="max-width: 40em">
    <div class="d-flex flex-row justify-content-center mt-5">
        <h1><%= typeof book !== 'undefined' ? 'Könyv módosítása' : 'Új könyv hozzáadása' %></h1>
    </div>

    <div class="mt-3">
        <form method="POST">
            <div class="mb-3">
                <label for="title" class="form-label">Cím</label>
                <input type="text" class="form-control" id="title" name="title" value="<%= typeof book !== 'undefined' ? book.title : '' %>" required>
            </div>
            <div class="mb-3">
                <label for="author" class="form-label">Író</label>
                <input type="text" class="form-control" id="author" name="author" value="<%= typeof book !== 'undefined' ? book.author : '' %>" required>
            </div>
            <div class="mb-3">
                <label for="genre" class="form-label">Műfaj</label>
                <select class="form-select" id="genre" name="genre" required>
                    <% genres.forEach(genre => { %>
                        <option value="<%= genre %>" <%= typeof book !== 'undefined' && book.genre === genre ? 'selected' : '' %>><%= genre %></option>
                    <% }); %>
                </select>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Leírás</label>
                <textarea class="form-control" id="description" name="description" rows="3" required><%= typeof book !== 'undefined' ? book.description : '' %></textarea>
            </div>
            <div class="d-flex flex-row justify-content-center mt-4">
                <div class="row gx-3">
                    <div class="col">
                        <button type="submit" class="btn btn-primary"><%= typeof book !== 'undefined' ? 'Módosítás' : 'Felvétel' %></button>
                    </div>
                    <div class="col">
                        <a class="btn btn-outline-primary" href="/database">Mégsem</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<%- include('footer') %>