<%- include('header') %>

<div class="container" style="max-width: 40em">
    <div class="d-flex flex-row justify-content-center mt-5">
        <h1>Értékelés - <%= book.title %></h1>
    </div>

    <div class="mt-3">
        <form method="POST">
            <div class="mb-3">
                <label for="rating" class="form-label">Értékelés: <span id="ratingValue">3</span></label>
                <input type="range" class="form-range" min="1" max="5" step="1" id="rating" name="rating" value="<%= typeof review !== 'undefined' ? review.rating : '3' %>" onchange="document.getElementById('ratingValue').textContent = this.value">
            </div>
            <div class="mb-3">
                <label for="text" class="form-label">Leírás</label>
                <textarea class="form-control" id="text" name="text" rows="3" required><%= typeof review !== 'undefined' ? review.text : '' %></textarea>
            </div>
            <div class="d-flex flex-row justify-content-center mt-4">
                <div class="row gx-3">
                    <div class="col">
                        <button type="submit" class="btn btn-primary">Értékelés</button>
                    </div>
                    <div class="col">
                        <a class="btn btn-outline-primary" href="/book/<%= book._id %>">Mégsem</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<%- include('footer') %>